---
interface Props {
	label: string;
	sublabel?: string;
	featuredLabel: string;
	featuredTint: "blue" | "sky";
	detailsTitle?: string;
}

const { label, sublabel, featuredLabel, featuredTint, detailsTitle } = Astro.props;
---

<div class="role-panel">
	<div class="role-panel-header">
		<div class="role-panel-label">{label}</div>
		{sublabel && <div class="role-panel-sublabel">{sublabel}</div>}
	</div>
	<div class:list={["role-panel-featured", `role-panel-featured--${featuredTint}`]}>
		<span class="role-panel-featured-label">{featuredLabel}</span>
		<span class="role-panel-featured-content"><slot name="featured" /></span>
	</div>
	<slot />
	{detailsTitle && (
		<details class="role-panel-details">
			<summary>{detailsTitle}</summary>
			<ul>
				<slot name="details" />
			</ul>
		</details>
	)}
</div>

<style>
	.role-panel-header {
		margin-bottom: 0.75rem;
	}
	.role-panel-label {
		font-size: 1.15rem;
		font-weight: 700;
	}
	.role-panel-sublabel {
		font-size: 0.8rem;
		opacity: 0.7;
	}
	.role-panel-featured {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 0.375rem;
		padding: 0.45rem 0.7rem;
		margin-bottom: 0.5rem;
	}
	.role-panel-featured--blue {
		background: rgba(90, 150, 255, 0.12);
	}
	.role-panel-featured--sky {
		background: rgba(56, 189, 248, 0.12);
	}
	.role-panel-featured-label {
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		opacity: 0.75;
		white-space: nowrap;
	}
	.role-panel-featured-content {
		font-size: 0.95rem;
	}
	.role-panel-details {
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 0.375rem;
		padding: 0.45rem 0.7rem;
		margin-bottom: 0.5rem;
		background: rgba(255, 255, 255, 0.04);
	}
	.role-panel-details > summary {
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		opacity: 0.75;
		cursor: pointer;
		list-style: none;
	}
	.role-panel-details > summary::-webkit-details-marker {
		display: none;
	}
	.role-panel-details > summary::after {
		content: "▾";
		float: right;
		opacity: 0.75;
		transition: transform 0.15s ease;
	}
	.role-panel-details[open] > summary::after {
		transform: rotate(180deg);
	}
	.role-panel-details ul {
		margin: 0.5rem 0 0;
		padding-left: 1.1rem;
	}
	.role-panel-details li {
		margin: 0.2rem 0;
	}

	:global(.dark) .role-panel,
	:global(.dark) .role-panel-header,
	:global(.dark) .role-panel-featured,
	:global(.dark) .role-panel-featured-label,
	:global(.dark) .role-panel-featured-content,
	:global(.dark) .role-panel-details,
	:global(.dark) .role-panel-details > summary {
		color: #fff;
	}
</style>
