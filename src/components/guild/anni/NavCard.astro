---
interface Props {
	href: string;
	title: string;
	description?: string;
	variant?: "default" | "cta";
}

const { href, title, description, variant = "default" } = Astro.props;
---

{variant === "default" ? (
	<a
		href={href}
		class="glass rounded p-4 block text-center transition hover:scale-[1.02] hover:no-underline no-underline"
	>
		<div class="flex justify-center">
			<slot name="icon" />
		</div>
		<h3 class="mt-2 mb-1">{title}</h3>
		{description && <p>{description}</p>}
	</a>
) : (
	<div class="not-prose my-8">
		<a
			href={href}
			class="block rounded-xl p-6 md:p-8 text-center text-black dark:text-white no-underline hover:no-underline transition hover:scale-[1.005] bg-sky-500/15 dark:bg-sky-400/20 border border-black/10 dark:border-white/15 shadow-md"
		>
			<div class="text-xs md:text-sm tracking-[0.12em] font-semibold opacity-90">
				<slot name="eyebrow" />
			</div>
			<div class="text-2xl md:text-4xl font-extrabold mt-1">{title}</div>
			<div class="text-sm md:text-base mt-2 font-semibold opacity-90">
				<slot name="footer">Click to Move to the Next Section -&gt;</slot>
			</div>
		</a>
	</div>
)}
