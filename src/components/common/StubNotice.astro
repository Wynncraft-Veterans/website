---
interface Props {
  title?: string;
}

const { title = "Stub" } = Astro.props;
---

<div
  class="not-prose my-0 rounded-lg border border-[rgba(255,255,255,0.3)] bg-fuchsia-200/35 px-3 py-1 backdrop-blur-lg dark:border-[rgba(255,255,255,0.07)] dark:bg-fuchsia-400/15"
  style="box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.18)"
  role="status"
  aria-label={title}
>
  <div class="flex items-center gap-1">
    <svg
      class="h-3 w-3 shrink-0 fill-current text-fuchsia-700 dark:text-fuchsia-200"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      aria-hidden="true"
    >
      <path d="M12.432 0c1.34 0 2.01.912 2.01 1.957 0 1.305-1.164 2.512-2.679 2.512-1.269 0-2.009-.75-1.974-1.99C9.789 1.436 10.67 0 12.432 0zM8.309 20c-1.058 0-1.833-.652-1.093-3.524l1.214-5.092c.211-.814.246-1.141 0-1.141-.317 0-1.689.562-2.502 1.117l-.528-.88c2.572-2.186 5.531-3.467 6.801-3.467 1.057 0 1.233 1.273.705 3.23l-1.391 5.352c-.246.945-.141 1.271.106 1.271.317 0 1.357-.392 2.379-1.207l.6.814C12.098 19.02 9.365 20 8.309 20z"/>
    </svg>

    <div class="m-0 text-sm leading-tight text-txt-p dark:text-darkmode-txt-p [&_p]:m-0 [&_p]:inline [&_p]:text-inherit">
      <span class="font-primary font-semibold text-txt-p dark:text-darkmode-txt-p">{title}</span>
      <span class="text-txt-p dark:text-darkmode-txt-p"> — <slot>This section has not yet been written. We hope to have it ready soon.</slot></span>
    </div>
  </div>
</div>
