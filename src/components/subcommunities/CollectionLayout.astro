---
import BaseLayout from "@components/base/BaseLayout.astro";
import CommunityCard from "@components/subcommunities/Card.astro";
import Pagination from "@components/common/Pagination.astro";
import PageHeader from "@components/common/PageHeader.astro";
import TabBar from "@components/subcommunities/TabBar.astro";
import type { SubcommunitiesEntry } from "@/types";

interface Props {
  entryIndex: SubcommunitiesEntry;
  entries: SubcommunitiesEntry[];
  pageIndex: number;
  pageCount: number;
  activeTab: "tool" | "community";
}

const { entryIndex, entries, pageIndex, pageCount, activeTab }: Props = Astro.props;

const basePath =
  activeTab === "tool" ? "/subcommunities" : "/subcommunities/communities";
---

<BaseLayout
  title={entryIndex.data.title}
  image={entryIndex.data.image?.src}
  description={entryIndex.data.description}
>
  <PageHeader title={entryIndex.data.title} />
  <TabBar active={activeTab} />
  <section class="section m-2">
    <div class="container">
      <div class="row">
        {
          entries.map((entry) => (
            <div class="md:col-6 lg:col-4 h-min p-2">
              <CommunityCard entry={entry} />
            </div>
          ))
        }
      </div>
      <Pagination
        basePath={basePath}
        pageIndex={pageIndex}
        pageCount={pageCount}
      />
    </div>
  </section>
</BaseLayout>
